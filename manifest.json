{
  "manifest_version": 3,
  "name": "Stensyl",
  "version": "1.0.0",
  "description": "Overlay design screenshots on live pages to compare your UI to the design like a stencil without juggling Figma and the browser.",
  "icons": {
    "16": "assets/images/logos/icon-16.png",
    "32": "assets/images/logos/icon-32.png",
    "48": "assets/images/logos/icon-48.png",
    "128": "assets/images/logos/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/images/logos/icon-16.png",
      "32": "assets/images/logos/icon-32.png",
      "48": "assets/images/logos/icon-48.png",
      "128": "assets/images/logos/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content/scroll.js",
        "content/state.js",
        "content/utils.js",
        "content/canvas-html.js",
        "content/image-drag.js",
        "content/canvas-controls.js",
        "content/canvas-flow.js",
        "content/overlay.js",
        "content/entry.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "unlimitedStorage"
  ]
}
